# =============================================================================
# Model checkpoints & training weights (way too large for GitHub)
# =============================================================================
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.tflite

# Whole checkpoint trees -- contain only large *.pt blobs plus tiny meta json.
# We want the meta json to be ignorable too; if you ever need to commit the
# tokenizer_meta.json, force-add with `git add -f`.
checkpoints/
model/checkpoints/
archive/**/checkpoints/

# =============================================================================
# Experiment tracking artifacts
# =============================================================================
# Weights & Biases local run cache (logs, sqlite, sync state).
wandb/
**/wandb/

# Raw stdout dumps from training/eval -- regeneratable, often huge.
# (We KEEP runs/curves_*.json and eval/results/**/summary.json -- those are
#  the canonical artifacts referenced from docs/experiment_tracking.md.)
runs/*.log
runs/screen_*.log
archive/**/runs/*.log
eval/results/**/run.log

# =============================================================================
# Audio / video assets (not redistributable + easy to regenerate)
# =============================================================================
*.mp3
*.mp4
*.wav
*.flac
*.mov
*.mkv

# =============================================================================
# Project-specific
# =============================================================================
# nanoGPT submodule-style clone used as a reference, not part of this repo.
notebooks/build_nanoGPT/build-nanogpt

# Old / scratch training data superseded by model/data/splits/.
model/data/train_old.jsonl

# Local-only scratch directories.
tmp/
.tmp/
scratch/


archive/v1_data_894ex/checkpoints/
archive/v1_data_894ex/runs/
archive/v1_data_894ex/eval_results/


